# pnpm configuration
# Use shamefully-hoist for better compatibility with tools that expect top-level dependencies
shamefully-hoist=true

# strict-peer-deps disabled to avoid peer dependency warnings that are not critical
strict-peer-dependencies=false

# Auto-install peer dependencies for better compatibility
auto-install-peers=true

# Prefer workspace protocol for monorepo support
prefer-workspace-packages=true

# Cache configuration
# cache-dir=~/.pnpm-cache
fetch-retries=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Performance
prefer-offline=false
verify-integrity=true
